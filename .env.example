# PostgreSQL connection string
# Example: postgresql://postgres:password@localhost:5432/mentorloop
DATABASE_URL=

# Set true when your DB host requires SSL (for managed Postgres providers)
PG_SSL=false

# Admin key for querying leads from /api/leads
ADMIN_API_KEY=change-this-admin-key

# Local server port
PORT=3000

# Allowed frontend origin for browser API calls
# Example: https://mentorloop.pages.dev
CORS_ORIGIN=*

